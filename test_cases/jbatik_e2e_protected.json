{
  "case": "jbatik_protected_api_test",
  "description": "Verify jBatik protected APIs work correctly using simulated login",
  "tasks": [
    {
      "task_type": "curl",
      "name": "trigger_get_csrf",
      "config": {
        "url": "http://localhost:8000/api/v1/jbatik/csrf",
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        },
        "body": {}
      },
      "output_format": "json"
    },
    {
      "task_type": "compare_json",
      "name": "verify_csrf_status",
      "config": {
        "source_task": "trigger_get_csrf",
        "field": "status_code",
        "expected": 200,
        "match_mode": "full"
      }
    },
    {
      "task_type": "curl",
      "name": "trigger_register_user",
      "config": {
        "url": "http://localhost:8000/api/customer/register",
        "method": "POST",
        "source_auth_task": "trigger_get_csrf",
        "headers": {
          "Accept": "application/json",
          "Content-Type": "application/json"
        },
        "body": {
          "first_name": "E2E",
          "last_name": "Test User",
          "email": "e2e_test_{{ lookup('pipe', 'date +%s') }}@jbatik.com",
          "password": "Password123!",
          "password_confirmation": "Password123!"
        }
      },
      "output_format": "json"
    },
    {
      "task_type": "compare_json",
      "name": "verify_register_status",
      "config": {
        "source_task": "trigger_register_user",
        "field": "status_code",
        "expected": 200,
        "match_mode": "full"
      }
    },
    {
      "task_type": "curl",
      "name": "trigger_get_designs",
      "config": {
        "url": "http://localhost:8000/api/v1/jbatik/user/designs",
        "method": "GET",
        "source_auth_task": "trigger_register_user",
        "headers": {
          "Accept": "application/json"
        },
        "body": {}
      },
      "output_format": "json"
    },
    {
      "task_type": "compare_json",
      "name": "verify_get_designs_status",
      "config": {
        "source_task": "trigger_get_designs",
        "field": "status_code",
        "expected": 200,
        "match_mode": "full"
      }
    }
  ]
}
